@model IEnumerable<ClinicaMedica.Models.Consulta>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<div class="d-flex gap-2 mb-3 align-items-center">
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Criar Novo
    </a>
    <a asp-action="ExportarExcel" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Exportar para Excel
    </a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PacienteId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Especialidade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NomeMedico)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DataHora)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Observacoes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Paciente.Nome)
            </td>
            <td>
                @Html.DisplayFor(model => item.Especialidade)
            </td>
            <td>
                @Html.DisplayFor(model => item.NomeMedico)
            </td>
            <td>
                @Html.DisplayFor(model => item.DataHora)
            </td>
            <td>
                @Html.DisplayFor(model => item.Observacoes)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
